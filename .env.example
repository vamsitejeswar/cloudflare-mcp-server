# Create at https://dash.cloudflare.com/profile/api-tokens
# Scope it to exactly what this server needs (Zone/DNS/Tunnel/Firewall/etc edit permissions).
CLOUDFLARE_API_TOKEN=your-api-token-here

# Found on the right sidebar of any zone's Overview page in the Cloudflare dashboard.
# Used as the default account_id for account-scoped tools (tunnels, KV, Access, etc)
# when a tool call omits it.
CLOUDFLARE_ACCOUNT_ID=your-account-id-here



